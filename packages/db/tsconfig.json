{
  "extends": "@repo/typescript-config/base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@models/*": ["src/models/*"],
      "@utils/*": ["src/utils/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "migrations", "seeders", "**/*.test.ts"],
  "ts-node": {
    "require": ["tsconfig-paths/register"],
    "files": true
  }
}
