{
  "name": "e-commerce",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:queues": "turbo run dev --parallel --filter=merchant-worker",
    "dev:merchant": "turbo run dev --parallel --filter=merchant... --filter=merchant-service...",
    "dev:portal": "turbo run dev --parallel --filter=portal... --filter=portal-service...",
    "dev:customer": "turbo run dev --parallel --filter=customer-service... --filter=customer...",
    "dev:customer2": "turbo run dev --parallel --filter=customer-service2... --filter=customer2...",
    "dev:authen": "turbo run dev --parallel --filter=authen-service...",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "eslint-config-prettier": "^10.1.5",
    "prettier": "^3.6.2",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "@types/node": "^24.0.14",
    "ts-node": "^10.9.2"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@swc/core": "^1.13.0"
  }
}
