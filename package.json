{
  "name": "e-commerce",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:digishop": "turbo run dev --parallel --filter=digishop-service... --filter=digishop...",
    "dev:merchant": "turbo run dev --parallel --filter=merchant... --filter=merchant-service... --filter=authen-service... --filter=gateway-service...",
    "dev:portal": "turbo run dev --parallel --filter=portal... --filter=portal-service...",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "eslint-config-prettier": "^10.1.5",
    "prettier": "^3.6.2",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@swc/core": "^1.13.0"
  }
}
