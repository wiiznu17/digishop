{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "globalEnv": ["JWT_SECRET", "NEXT_PUBLIC_*"],

  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "migrate:all": {
      "cache": false
    },
    "migrate:undo": {
      "cache": false
    },
    "seed": {
      "cache": false
    },
    "seed:undo": {
      "cache": false
    },
    "migrate": {
      "cache": false
    }
  }
}
